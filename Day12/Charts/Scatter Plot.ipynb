    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "\n",
    "x = np.random.randint(1,10,50)\n",
    "y = np.random.randint(10,100,50)\n",
    "\n",
    "color = np.random.randint(10,100,50)\n",
    "\n",
    "plt.scatter(x,y, marker = \"*\", cmap = \"hot\", c = color)\n",
    "plt.colorbar()\n",
    "plt.show()"
   ]
  }
